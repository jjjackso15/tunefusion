{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm --prefix ../desktop run dev",
    "beforeBuildCommand": "npm --prefix ../desktop run build",
    "devPath": "http://localhost:5173",
    "distDir": "../desktop/dist"
  },
  "package": {
    "productName": "TuneFusion",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "open": true
      }
    },
    "windows": [
      {
        "title": "TuneFusion",
        "width": 960,
        "height": 700
      }
    ]
  }
}
